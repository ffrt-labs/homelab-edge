# homelab-edge configuration
# Copy this file to .env and fill in your values

# Bare domain — no subdomain, no scheme. The Caddyfile prepends "*." itself,
# so a wildcard cert covers every app's subdomain automatically.
EDGE_BASE_DOMAIN=yourdomain.com

# Cloudflare API token used for the DNS-01 challenge.
#   - Create at: Cloudflare dashboard -> profile icon -> My Profile -> API Tokens
#   - Use the "Edit zone DNS" template
#   - Scope it to Zone:DNS:Edit on this one zone only — NOT the Global API Key
CLOUDFLARE_API_TOKEN=
